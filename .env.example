# ╔══════════════════════════════════════════════════════════════╗
# ║  OS4U — Variáveis de Ambiente                               ║
# ║  Copie para .env e preencha antes do deploy                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Banco de Dados ─────────────────────────────────────────────
DB_USERNAME=os4u
DB_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
DB_DATABASE=assistencia_db

# ── Segurança (OBRIGATÓRIO mudar) ──────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_LONGA_AQUI
JWT_EXPIRES_IN=7d

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=https://SEU_DOMINIO.com.br
VITE_API_URL=https://api.SEU_DOMINIO.com.br

# ── WhatsApp — Evolution API (opcional) ───────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_ID=

# ── E-mail SMTP (opcional, para envio de orçamentos/NF) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=Assistência Técnica <seu@email.com>

# ── Fotos das OS — Cloudinary (opcional) ──────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Fiscal NF-e (apenas se emitir nota) ───────────────────────
FISCAL_AMBIENTE=2   # 2=homologação, 1=produção
FISCAL_CERT_PASSWORD=
FISCAL_EMITENTE_CNPJ=
FISCAL_EMITENTE_RAZAO_SOCIAL=
FISCAL_EMITENTE_UF=SC
FISCAL_EMITENTE_CRT=1  # 1=Simples Nacional
