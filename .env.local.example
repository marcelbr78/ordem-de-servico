# ╔══════════════════════════════════════════════════════════════╗
# ║  OS4U — .env para notebook da loja                          ║
# ║  Copie para .env e preencha                                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ── OBRIGATÓRIO: IP do notebook na rede Wi-Fi da loja ──────────
# Descobrir: Windows = ipconfig | Linux/Mac = ip a
# Exemplo: 192.168.1.100
VITE_API_URL=http://192.168.1.100:3005

# ── OBRIGATÓRIO: senha do banco (qualquer senha forte) ─────────
DB_PASSWORD=minha_senha_segura_aqui

# ── OBRIGATÓRIO: chave secreta do JWT ─────────────────────────
# Gere: node -e "console.log(Math.random().toString(36).repeat(5))"
JWT_SECRET=coloque_uma_string_longa_e_aleatoria_aqui

# ── WhatsApp (opcional — preencher se tiver Evolution API) ─────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_ID=

# ── E-mail (opcional — para enviar orçamentos por e-mail) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Fotos das OS — Cloudinary (opcional, gratuito) ────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
